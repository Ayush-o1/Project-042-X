# ── Backend (backend/.env) ───────────────────────────────────────────
# All values are optional; these are the defaults.
PORT=5001
# The backend binds to loopback only. Do not expose it to the network:
# it reads local files on behalf of the frontend.
HOST=127.0.0.1
# Comma-separated CORS allowlist. Defaults to any localhost/127.0.0.1 port.
# ALLOWED_ORIGINS=http://localhost:5173

# ── Frontend (frontend/.env) ─────────────────────────────────────────
# Optional; defaults to http://localhost:5001/api/v1.
VITE_API_URL=http://localhost:5001/api/v1
