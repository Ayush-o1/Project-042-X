    "test": "vitest run src/"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20.19"
  },
  "type": "commonjs",
  "dependencies": {
    "@swc/core": "^1.15.43",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "ignore": "^7.0.6",
    "p-limit": "^7.3.0",
    "simple-git": "^3.36.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/supertest": "^7.2.1",
    "supertest": "^7.2.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
